# ─────────────────────────────────────────────────────────────────────────────
# COPIE este arquivo para .env e preencha os valores antes de rodar o projeto.
#   cp .env.example .env
# O arquivo .env NÃO é versionado (está no .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=troque_esta_senha
DB_NAME=ValisysProduction

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=gere_uma_chave_forte_de_64_bytes_aqui

# ── AWS S3 (opcional – deixe em branco para desabilitar uploads) ──────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=
AWS_REGION=sa-east-1
